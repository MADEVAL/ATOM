{
    "name": "atom/framework",
    "description": "Atom - PHP 8.5 micro-framework. Single PCRE router, template engine, DI, validation, sessions, CLI.",
    "type": "library",
    "keywords": ["framework", "micro-framework", "php", "router", "pcre", "template"],
    "license": "GPL-3.0-or-later",
    "homepage": "https://github.com/php-atom/framework",
    "authors": [
        {
            "name": "Atom Contributors"
        }
    ],
    "require": {
        "php": ">=8.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Atom\\": "src/Atom/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Atom\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/atom"
    ],
    "scripts": {
        "serve": "php -S localhost:8000 -t public",
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-text"
    }
}
